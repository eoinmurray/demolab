---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="mx-auto max-w-2xl px-6 py-16">
    <header class="mb-16">
      <a href={import.meta.env.BASE_URL} class="text-sm tracking-wide uppercase text-neutral-500 hover:text-neutral-900">
        ← Index
      </a>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
