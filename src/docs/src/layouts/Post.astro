---
import Base from './Base.astro';
interface Props {
  title: string;
  date: Date;
  description?: string;
}
const { title, date, description } = Astro.props;
const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<Base title={title}>
  <article class="prose prose-neutral max-w-none prose-headings:font-serif prose-headings:font-normal">
    <header class="mb-10 not-prose">
      <h1 class="text-3xl font-normal mb-2">{title}</h1>
      <p class="text-sm text-neutral-500">{formatted}</p>
      {description && <p class="mt-4 text-neutral-700 italic">{description}</p>}
    </header>
    <slot />
  </article>
</Base>
