---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Base title="Notes">
  <h1 class="text-2xl font-normal mb-12">Notes</h1>
  <ul class="space-y-3">
    {posts.map((post) => {
      const date = post.data.date.toLocaleDateString('en-US', {
        year: 'numeric', month: 'short', day: 'numeric',
      });
      return (
        <li class="flex gap-6 items-baseline">
          <time class="text-sm text-neutral-500 tabular-nums shrink-0 w-28">{date}</time>
          <a href={`/posts/${post.id}/`} class="underline decoration-neutral-300 hover:decoration-neutral-900">
            {post.data.title}
          </a>
        </li>
      );
    })}
  </ul>
</Base>
