---
import Base from '../layouts/Base.astro';
import EntryList from '../components/EntryList.astro';
import { loadAllEntries, bucketize, UNCOLLECTED } from '../lib/entries';

const { articles, notebooks } = await loadAllEntries();
const buckets = bucketize(articles, notebooks);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="demolab" isHome={true}>
  <div class="[&_a]:no-underline! [&_a:hover]:underline!">
    <div class="flex flex-col gap-12">
      {buckets.map((bucket) => (
        <section>
          <p class="mb-2 text-xs uppercase tracking-wider text-[color:var(--color-muted)]">
            {bucket.collection === UNCOLLECTED ? (
              bucket.label
            ) : (
              <a href={`${base}/collections/${bucket.collection}/`}>{bucket.label}</a>
            )}
          </p>
          <EntryList entries={bucket.articles} />
          <EntryList entries={bucket.notebooks} />
        </section>
      ))}
    </div>
  </div>
</Base>
