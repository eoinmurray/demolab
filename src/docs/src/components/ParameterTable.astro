---
interface Props {
  title?: string;
  params: Record<string, unknown>;
}
const { title, params } = Astro.props;
const format = (value: unknown): string => {
  if (typeof value === 'number') {
    return Number.isInteger(value) ? value.toString() : value.toString();
  }
  return String(value);
};
---
<figure class="not-prose my-6">
  {title && <figcaption class="text-sm font-medium text-neutral-700 mb-2">{title}</figcaption>}
  <table class="text-sm border border-neutral-200 max-w-md w-full">
    <thead class="bg-neutral-50 text-neutral-500">
      <tr>
        <th class="px-3 py-1.5 text-left font-medium">Parameter</th>
        <th class="px-3 py-1.5 text-right font-medium">Value</th>
      </tr>
    </thead>
    <tbody>
      {Object.entries(params).map(([key, value]) => (
        <tr class="border-t border-neutral-200">
          <td class="px-3 py-1.5 font-mono text-neutral-700">{key}</td>
          <td class="px-3 py-1.5 text-right font-mono">{format(value)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</figure>
